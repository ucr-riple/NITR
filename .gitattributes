* text=auto

*.sh text eol=lf
*.py text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.csv text eol=lf
*.env text eol=lf
*.example text eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# Vendored third-party code is not subject to line-ending normalization.
# This rule must come last so it overrides the extension rules above.
third_party/**  -text
