{
  "case_root": "../../.submit-output/chatgpt-api/cases/026.inline-filter-entrypoint-reuse-python",
  "baseline_case_root": "../../cases/026.inline-filter-entrypoint-reuse-python",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "required_paths",
      "name": "case026_required_layout",
      "paths": [
        "src/filter_clause.py",
        "src/filter_rule.py",
        "src/filter_parser.py",
        "src/filter_validation.py"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "case026_functional_tests",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^case026_functional_tests$"
      ]
    },
    {
      "module_name": "customized_check",
      "name": "case026_structural_check",
      "command": [
        "python3",
        "{evaluator_root}/checks/run_evaluator.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
