{
  "case_root": "../../.submit-output/chatgpt-api/cases/003.reuse-existing-code",
  "baseline_case_root": "../../cases/003.reuse-existing-code",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "build",
      "name": "build_case003_functional_tests",
      "command": [
        "cmake",
        "--build",
        "{build_dir}",
        "--target",
        "case003_functional_tests",
        "-j4"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "case003_functional_tests",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^case003_functional_tests$"
      ]
    },
    {
      "module_name": "baseline_diff",
      "name": "case003_file_boundary_check",
      "include_globs": [
        "src/**/*"
      ],
      "exclude_globs": [
        "**/CMakeLists.txt"
      ],
      "allow_modified": [
        "src/cosine_similarity.cc"
      ]
    },
    {
      "module_name": "source_analysis",
      "name": "case003_reuse_structure_check",
      "root": "case_root",
      "scan_roots": [
        "src/cosine_similarity.cc"
      ],
      "rules": [
        {
          "id": "require_dot_product_include",
          "not": {
            "any_patterns": [
              "#include\\s+\"dot_product\\.h\""
            ]
          },
          "message": "Structural reuse check failed: missing #include \"dot_product.h\" in src/cosine_similarity.cc"
        },
        {
          "id": "require_l2_norm_include",
          "not": {
            "any_patterns": [
              "#include\\s+\"l2_norm\\.h\""
            ]
          },
          "message": "Structural reuse check failed: missing #include \"l2_norm.h\" in src/cosine_similarity.cc"
        },
        {
          "id": "require_dot_product_call",
          "not": {
            "any_patterns": [
              "(?:nitr::case003::)?DotProduct\\s*\\("
            ]
          },
          "message": "Structural reuse check failed: missing DotProduct(...) call in src/cosine_similarity.cc"
        },
        {
          "id": "require_l2_norm_call",
          "not": {
            "any_patterns": [
              "(?:nitr::case003::)?L2Norm\\s*\\("
            ]
          },
          "message": "Structural reuse check failed: missing L2Norm(...) call in src/cosine_similarity.cc"
        },
        {
          "id": "forbid_sqrt_reimplementation",
          "any_patterns": [
            "\\bsqrt\\s*\\("
          ],
          "message": "Structural check failed: detected likely re-implementation of math utilities in src/cosine_similarity.cc"
        },
        {
          "id": "forbid_sum_sq_reimplementation",
          "any_patterns": [
            "sum_sq\\s*\\+="
          ],
          "message": "Structural check failed: detected likely re-implementation of math utilities in src/cosine_similarity.cc"
        },
        {
          "id": "forbid_sum_multiply_reimplementation",
          "any_patterns": [
            "sum\\s*\\+=\\s*[^;]*\\*[^;]*;"
          ],
          "message": "Structural check failed: detected likely re-implementation of math utilities in src/cosine_similarity.cc"
        }
      ]
    }
  ]
}
