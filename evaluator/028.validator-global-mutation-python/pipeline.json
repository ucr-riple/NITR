{
  "case_root": "../../.submit-output/chatgpt-api/cases/028.validator-global-mutation-python",
  "baseline_case_root": "../../cases/028.validator-global-mutation-python",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "required_paths",
      "name": "case028_required_layout",
      "paths": [
        "src/submission.py",
        "src/validator.py",
        "src/grader.py",
        "src/reporter.py",
        "src/stats.py"
      ]
    },
    {
      "module_name": "baseline_diff",
      "name": "case028_protected_files_check",
      "paths": [
        "app/main.py",
        "src/grader.py",
        "src/reporter.py",
        "src/stats.py"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "case028_validator_tests",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^case028_validator_tests$"
      ]
    },
    {
      "module_name": "customized_check",
      "name": "case028_structural_check",
      "command": [
        "python3",
        "{evaluator_root}/checks/run_evaluator.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
