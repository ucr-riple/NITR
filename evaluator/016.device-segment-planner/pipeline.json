{
  "case_root": "../../.submit-output/chatgpt-api/cases/016.device-segment-planner",
  "baseline_case_root": "../../cases/016.device-segment-planner",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "build",
      "name": "build_case016_targets",
      "command": [
        "cmake",
        "--build",
        "{build_dir}",
        "--target",
        "test_config_loader_smoke",
        "test_runner_smoke",
        "test_execution_plan_legacy",
        "test_execution_plan_updated",
        "test_execution_plan_unseen",
        "test_runner_respects_segmentation",
        "-j4"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_config_loader_smoke",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_config_loader_smoke$"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_runner_smoke",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_runner_smoke$"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_execution_plan_legacy",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_execution_plan_legacy$"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_execution_plan_updated",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_execution_plan_updated$"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_execution_plan_unseen",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_execution_plan_unseen$"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_runner_respects_segmentation",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_runner_respects_segmentation$"
      ]
    },
    {
      "module_name": "source_analysis",
      "name": "require_planner_usage_check",
      "root": "case_root",
      "scan_roots": [
        "src/pipeline_runner.cc"
      ],
      "rules": [
        {
          "id": "require_build_execution_plan_call",
          "not": {
            "any_substrings": [
              "BuildExecutionPlan("
            ]
          },
          "message": "pipeline_runner.cc does not appear to call BuildExecutionPlan(...)"
        }
      ]
    },
    {
      "module_name": "source_analysis",
      "name": "no_step_index_special_case_check",
      "root": "case_root",
      "scan_roots": [
        "src"
      ],
      "suffixes": [
        ".cc"
      ],
      "rules": [
        {
          "id": "no_hardcoded_step_4",
          "any_patterns": [
            "==\\s*4"
          ],
          "message": "{relative_path}: matched ==\\s*4"
        },
        {
          "id": "no_hardcoded_step_6",
          "any_patterns": [
            "==\\s*6"
          ],
          "message": "{relative_path}: matched ==\\s*6"
        },
        {
          "id": "no_hardcoded_step_3",
          "any_patterns": [
            "==\\s*3"
          ],
          "message": "{relative_path}: matched ==\\s*3"
        },
        {
          "id": "no_hardcoded_step_5",
          "any_patterns": [
            "==\\s*5"
          ],
          "message": "{relative_path}: matched ==\\s*5"
        },
        {
          "id": "no_legacy_gpu_through_step_branch",
          "any_patterns": [
            "legacy_gpu_through_step\\(\\)\\.value\\(\\)\\s*=="
          ],
          "message": "{relative_path}: matched legacy_gpu_through_step\\(\\)\\.value\\(\\)\\s*=="
        }
      ]
    }
  ]
}
