{
  "case_root": "../../.submit-output/chatgpt-api/cases/010.logging-side-effects",
  "baseline_case_root": "../../cases/010.logging-side-effects",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "build",
      "name": "build_loan_review_test",
      "command": [
        "cmake",
        "--build",
        "{build_dir}",
        "--target",
        "loan_review_test",
        "-j4"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "loan_review_test",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^loan_review_test$"
      ]
    },
    {
      "module_name": "command",
      "name": "maintainability_check_case010",
      "command": [
        "python3",
        "{evaluator_root}/checks/check.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
