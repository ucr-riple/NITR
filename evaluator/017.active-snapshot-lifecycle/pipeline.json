{
  "case_root": "../../.submit-output/chatgpt-api/cases/017.active-snapshot-lifecycle",
  "baseline_case_root": "../../cases/017.active-snapshot-lifecycle",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "build",
      "name": "build_case017_lifecycle_tests",
      "command": [
        "cmake",
        "--build",
        "{build_dir}",
        "--target",
        "case017_lifecycle_tests",
        "-j4"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "case017_lifecycle_tests",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^case017_lifecycle_tests$"
      ]
    },
    {
      "module_name": "command",
      "name": "case017_structure_checks",
      "command": [
        "python3",
        "{evaluator_root}/checks/check_structure.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
