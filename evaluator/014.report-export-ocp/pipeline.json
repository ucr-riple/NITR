{
  "case_root": "../../.submit-output/chatgpt-api/cases/014.report-export-ocp",
  "baseline_case_root": "../../cases/014.report-export-ocp",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "build",
      "name": "build_test_report_export",
      "command": [
        "cmake",
        "--build",
        "{build_dir}",
        "--target",
        "test_report_export",
        "-j4"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_report_export",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_report_export$"
      ]
    },
    {
      "module_name": "command",
      "name": "case014_structural_check",
      "command": [
        "python3",
        "{evaluator_root}/checks/check_structure.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
