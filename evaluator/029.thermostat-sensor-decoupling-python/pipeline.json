{
  "case_root": "../../.submit-output/chatgpt-api/cases/029.thermostat-sensor-decoupling-python",
  "baseline_case_root": "../../cases/029.thermostat-sensor-decoupling-python",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "required_paths",
      "name": "case029_required_layout",
      "paths": [
        "src/thermostat_controller.py",
        "src/tmp26_sensor.py",
        "app/main.py"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "case029_thermostat_tests",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^case029_thermostat_tests$"
      ]
    },
    {
      "module_name": "customized_check",
      "name": "case029_structural_check",
      "command": [
        "python3",
        "{evaluator_root}/checks/run_evaluator.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
