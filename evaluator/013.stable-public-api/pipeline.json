{
  "case_root": "../../.submit-output/chatgpt-api/cases/013.stable-public-api",
  "baseline_case_root": "../../cases/013.stable-public-api",
  "build_dir": "../../build",
  "modules": [
    {
      "module_name": "build",
      "name": "build_test_catalog",
      "command": [
        "cmake",
        "--build",
        "{build_dir}",
        "--target",
        "test_catalog",
        "-j4"
      ]
    },
    {
      "module_name": "unit_test",
      "name": "test_catalog",
      "command": [
        "ctest",
        "--test-dir",
        "{build_dir}",
        "--output-on-failure",
        "-R",
        "^test_catalog$"
      ]
    },
    {
      "module_name": "command",
      "name": "case013_api_stability_check",
      "command": [
        "python3",
        "{evaluator_root}/checks/check_api_stability.py",
        "--case_root",
        "{case_root}"
      ],
      "env": {
        "PYTHONPATH": "{repo_root}"
      }
    }
  ]
}
